      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE3NzNGQUI5RDNFOEY0MzUKUldRMTlPalR1ZnB6cDhkMXpvTGsrZE5wZk1Wei92Kzc5dzRKRDJ1RTQ1dHFrWHkyYndoSmF4QjYK",
      "endpoints": [
        "https://wnozfcqgcmvxvkxbxgfj.supabase.co/storage/v1/object/public/app-releases/updater.json"
      ]
    },
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "active": true,
